# GoLaundry Backend — Required Environment Variables
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to version control.

# ─── Django Core ────────────────────────────────────────────────────────────────
# Generate a strong secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-replace-this-with-a-real-secure-key-in-production

# Set to True only for local development; must be False in production
DEBUG=True

# Comma-separated list of allowed host/domain names
# Render automatically exposes RENDER_EXTERNAL_HOSTNAME — no need to set this manually there
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
# For local dev you can omit this and fall back to SQLite
DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_laundry

# ─── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of fully-qualified frontend origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3008

# ─── JWT (Optional — defaults used if omitted) ───────────────────────────────────
# JWT_SECRET_KEY=fallback-to-django-secret-key-if-not-set
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Security (Production only — set in Render dashboard) ───────────────────────
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
